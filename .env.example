# OKF Compiler LLM configuration
# Copy this file to .env and fill in your provider values.
#
# Resolution priority:
#   CLI flags > process environment > .env > defaults

# OpenAI-compatible API base URL. Usually ends in /v1.
OKF_LLM_BASE_URL=https://api.openai.com/v1

# LiteLLM model name. With a custom base URL, bare names are routed as openai/<name>.
OKF_LLM_MODEL=gpt-4.1-mini

# API key. Never commit a real key; .env is ignored by Git.
OKF_LLM_API_KEY=

# Request timeout in seconds.
OKF_LLM_TIMEOUT=120
